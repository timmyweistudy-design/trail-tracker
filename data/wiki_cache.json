, "紗帽路磺溪小徑": null, "紫微保甲路步道": null, "紫明溪步道": null, "絹絲瀑布步道": null, "綠島觀海步道": null, "綠島阿眉山步道": null, "綠水合流步道": null, "綠水文山步道": null, "綠色長城-三腳南山系": null, "綠色長城-大凍山系": null, "綠色長城-大烏山系": null, "綠色隧道": {"extract": "綠色隧道是指道路兩側的整排樹木的枝叶形成了一連串的树冠，营造出如隧道般的视觉效果。这种效果既可通过人工規劃的林蔭大道实现，亦能借乡间小径两侧自然生长的树木达成。\n", "url": "https://zh.wikipedia.org/wiki/%E7%B6%A0%E8%89%B2%E9%9A%A7%E9%81%93"}, "羅木斯溪登山步道": null, "羅馬縱走": null, "羊稠步道": null, "羊頭山步道": null, "美濃越嶺古道": null, "美濃雙溪樹木園步道": null, "美濃靈山登山步道": null, "義松小徑": null, "翠山步道": null, "翠峰湖環山步道": null, "老佛山步道": null, "老銃櫃步道": null, "老鷹溪步道": null, "聖母登山步道": {"extract": "聖母登山步道，起點為台灣宜蘭縣礁溪鄉五峰旗瀑布風景區，終點為觀景平台。途經天主堂、涼亭、景觀平台及聖母山莊，並為通往三角崙山的中繼站，由林務局轄管。\n", "url": "https://zh.wikipedia.org/wiki/%E8%81%96%E6%AF%8D%E7%99%BB%E5%B1%B1%E6%AD%A5%E9%81%93"}, "聖稜線": {"extract": "聖稜線 是臺灣中北部的雪山山脈北從大霸尖山 南至雪山 連峰間高峻的山稜線，在雪霸國家公園範圍內。整段南北連亙的稜線，從雪山到大霸尖山，直線距離約8.7公里、步道長約11.8公里，西側屬苗栗縣泰安鄉，水系屬雪山溪流域（大安溪水系）；稜線北段的東側屬新竹縣尖石鄉，水系屬塔克金溪流域（淡水河水系）；稜線南段的東側屬台中市和平區，水系屬七家灣溪流域（大甲溪水系）。\n", "url": "https://zh.wikipedia.org/wiki/%E8%81%96%E7%A8%9C%E7%B7%9A"}, "能高安東軍縱走": null, "能高越嶺道": {"extract": "能高越嶺道，又稱能高越道路，常簡稱為能高越，是臺灣一條從能高山北側東西越嶺中央山脈的歷史古道，原是賽德克族與太魯閣族行獵、貿易與遷徙的路徑，在日治時期被修建成正式道路。日治時1917–1918年所開鑿由奇萊裡山（聯帶山）南坡越嶺的舊道稱為能高越橫斷道路，舊道東段以頭尾兩端的地名又稱為初音奇萊橫斷道路，1925年舊道東段因越嶺點海拔過高，更改成大致為現今由能高埡口越嶺的路線，為與舊道區別，改線後稱為能高越警備道路，現常被俗稱為能高越嶺古道。\n", "url": "https://zh.wikipedia.org/wiki/%E8%83%BD%E9%AB%98%E8%B6%8A%E5%B6%BA%E9%81%93"}, "能高越嶺道-西段": null, "能高越嶺道：東段": null, "興福寮登山步道": null, "芉蓁坑古道": null, "芉蓁坑溪畔古道": null, "苗冷古道": null, "苧仔潭古道": null, "苳柏步道": null, "茂興懷舊步道": null, "茅埔城古道": null, "茶之道步道": null, "茶亭古道": null, "茶園坪步道": null, "茶山古道": null, "茶山步道": null, "茶留凡山東南峰登山路徑": null, "茶香步道": null, "草原步道": null, "草嶺古道福隆路線": null, "草濫古道": null, "荷蘭古道": null, "菁桐古道": null, "菜公坑山步道": null, "華山3號步道": null, "華山4-2號步道": null, "華巴諾支線": null, "萬壽山步道": null, "蕨山登山路線": null, "蕨影步道": null, "薯榔尖登山步道": null, "藤坪步道": null, "蘇花古道：大南澳越嶺段": null, "蘭陽登山步道": null, "虎子山古道": null, "虎寮潭山路線": null, "虎山親山步道": null, "虎形山公園步道": null, "虎豹潭古道環形路線": null